            addCorner(knob, 11)

            local function setState(s)
                isOn = s
                tw(track, { BackgroundColor3 = s and C.BG or C.TOGGLE_OFF })
                tw(knob,  { Position = s and UDim2.fromOffset(30, 4) or UDim2.fromOffset(4, 4) })
                cb.fn(s)
            end
            track.MouseButton1Click:Connect(function() setState(not isOn) end)
            return {
                Instance = card, GetState = function() return isOn end,
                SetState = function(_, s) setState(s) end,
                SetCallback = function(_, f) cb.fn = f end,
            }
        end

        function Tab:AddSlider(cfg)
            cfg = cfg or {}
            local nm  = cfg.Name or "Slider" ; local ds = cfg.Desc or ""
            local mn  = cfg.Min or 0 ; local mx = cfg.Max or 100
            local def = cfg.Default or mn ; local hasD = ds ~= ""
            local cb  = { fn = cfg.Callback or function() end }
            local card = mkCard(hasD and 96 or 80)

            local nL = Instance.new("TextLabel")
            nL.Size = UDim2.new(0.65, 0, 0, 20) ; nL.Position = UDim2.new(0, 12, 0, hasD and 10 or 12)
            nL.BackgroundTransparency = 1 ; nL.Text = nm ; nL.TextColor3 = C.TXT_DK
            nL.Font = Enum.Font.GothamBold ; nL.TextSize = 14
            nL.TextXAlignment = Enum.TextXAlignment.Left ; nL.Parent = card

            local vL = Instance.new("TextLabel")
            vL.Size = UDim2.new(0.35, -12, 0, 20) ; vL.Position = UDim2.new(0.65, 0, 0, hasD and 10 or 12)
            vL.BackgroundTransparency = 1 ; vL.Text = tostring(def) ; vL.TextColor3 = C.TXT_DK
            vL.Font = Enum.Font.GothamBold ; vL.TextSize = 14
            vL.TextXAlignment = Enum.TextXAlignment.Right ; vL.Parent = card

            if hasD then
                local dL = Instance.new("TextLabel")
                dL.Size = UDim2.new(1, -24, 0, 14) ; dL.Position = UDim2.new(0, 12, 0, 34)
                dL.BackgroundTransparency = 1 ; dL.Text = ds ; dL.TextColor3 = C.TXT_MUT
                dL.Font = Enum.Font.Gotham ; dL.TextSize = 11
                dL.TextXAlignment = Enum.TextXAlignment.Left ; dL.Parent = card
            end

            local sw = makeFrame(card, {
                Size = UDim2.new(1, -24, 0, 40),
                Position = UDim2.new(0, 12, 0, hasD and 50 or 38),
            })
            buildSlider(sw, mn, mx, def, C.DARK, function(v)
                vL.Text = tostring(v) ; cb.fn(v)
            end)
            return { Instance = card, SetCallback = function(_, f) cb.fn = f end }
        end

        function Tab:AddDropdown(cfg)
            cfg = cfg or {}
            local nm  = cfg.Name or "Dropdown" ; local opts = cfg.Options or {}
            local cb  = { fn = cfg.Callback or function() end }
            local sel = cfg.Default or (opts[1] or "–")
            local IH  = 44 ; local HH = 52 ; local open = false

            local card = makeFrame(tabFrame, {
                Size = UDim2.new(1, 0, 0, HH),
                BackgroundColor3 = C.CARD, BackgroundTransparency = 0,
                ClipsDescendants = true,
            })
            addCorner(card, 8)

            local nL = Instance.new("TextLabel")
            nL.Size = UDim2.new(1, -120, 0, HH) ; nL.Position = UDim2.new(0, 12, 0, 0)
            nL.BackgroundTransparency = 1 ; nL.Text = nm ; nL.TextColor3 = C.TXT_DK
            nL.Font = Enum.Font.GothamBold ; nL.TextSize = 14
            nL.TextXAlignment = Enum.TextXAlignment.Left ; nL.Parent = card

            local selBtn = Instance.new("TextButton")
            selBtn.Size = UDim2.new(0, 106, 0, 36) ; selBtn.Position = UDim2.new(1, -114, 0.5, -18)
            selBtn.BackgroundColor3 = C.DARK ; selBtn.Text = sel .. " ▾"
            selBtn.TextColor3 = C.TXT_LT ; selBtn.Font = Enum.Font.Gotham ; selBtn.TextSize = 12
            selBtn.TextTruncate = Enum.TextTruncate.AtEnd
            selBtn.BorderSizePixel = 0 ; selBtn.AutoButtonColor = false ; selBtn.Parent = card
            addCorner(selBtn, 7) ; addPadding(selBtn, 0, 8, 0, 8)
            selBtn.MouseEnter:Connect(function() tw(selBtn, { BackgroundColor3 = C.HOVER }) end)
            selBtn.MouseLeave:Connect(function() tw(selBtn, { BackgroundColor3 = C.DARK  }) end)

            local optList = makeFrame(card, {
                Size = UDim2.new(1, 0, 0, #opts * IH), Position = UDim2.new(0, 0, 0, HH),
                BackgroundColor3 = C.CARD_DARK, BackgroundTransparency = 0,
            })
            makeListLayout(optList, Enum.FillDirection.Vertical,
                Enum.HorizontalAlignment.Left, Enum.VerticalAlignment.Top, 0)

            for _, opt in ipairs(opts) do
                local ob = Instance.new("TextButton")
                ob.Size = UDim2.new(1, 0, 0, IH)
                ob.BackgroundColor3 = C.CARD_DARK ; ob.BackgroundTransparency = 1
                ob.Text = "   " .. opt ; ob.TextColor3 = Color3.fromRGB(205, 205, 205)
                ob.Font = Enum.Font.Gotham ; ob.TextSize = 13
                ob.TextXAlignment = Enum.TextXAlignment.Left
                ob.BorderSizePixel = 0 ; ob.AutoButtonColor = false ; ob.Parent = optList
                ob.MouseEnter:Connect(function() tw(ob, { BackgroundTransparency = 0.65 }) end)
                ob.MouseLeave:Connect(function() tw(ob, { BackgroundTransparency = 1    }) end)
                local cap = opt
                ob.MouseButton1Click:Connect(function()
                    sel = cap ; selBtn.Text = cap .. " ▾"
                    tw(card, { Size = UDim2.new(1, 0, 0, HH) })
                    open = false ; cb.fn(cap)
                end)
            end

            selBtn.MouseButton1Click:Connect(function()
                open = not open
                tw(card, { Size = UDim2.new(1, 0, 0, open and (HH + #opts * IH) or HH) })
                selBtn.Text = sel .. (open and " ▴" or " ▾")
            end)
            return {
                Instance = card, GetSelected = function() return sel end,
                SetCallback = function(_, f) cb.fn = f end,
            }
        end

        function Tab:AddTextBox(cfg)
            cfg = cfg or {}
            local nm = cfg.Name or "TextBox" ; local ph = cfg.Placeholder or "Type here…"
            local cb = { fn = cfg.Callback or function() end }
            local card = mkCard(72)

            local nL = Instance.new("TextLabel")
            nL.Size = UDim2.new(1, -12, 0, 20) ; nL.Position = UDim2.new(0, 12, 0, 8)
            nL.BackgroundTransparency = 1 ; nL.Text = nm ; nL.TextColor3 = C.TXT_DK
            nL.Font = Enum.Font.GothamBold ; nL.TextSize = 14
            nL.TextXAlignment = Enum.TextXAlignment.Left ; nL.Parent = card

            local box = Instance.new("TextBox")
            box.Size = UDim2.new(1, -24, 0, 34) ; box.Position = UDim2.new(0, 12, 0, 32)
            box.BackgroundColor3 = C.DARK ; box.Text = "" ; box.PlaceholderText = ph
            box.TextColor3 = C.TXT_LT ; box.PlaceholderColor3 = Color3.fromRGB(110, 110, 110)
            box.Font = Enum.Font.Gotham ; box.TextSize = 14
            box.BorderSizePixel = 0 ; box.ClearTextOnFocus = false ; box.Parent = card
            addCorner(box, 7) ; addPadding(box, 0, 10, 0, 10)
            box.FocusLost:Connect(function(enterPressed) cb.fn(box.Text, enterPressed) end)
            return {
                Instance = card,
                GetText  = function()      return box.Text end,
                SetText  = function(_, t)  box.Text = t end,
                Clear    = function()      box.Text = "" end,
                SetCallback = function(_, f) cb.fn = f end,
            }
        end

        function Tab:AddKeybind(cfg)
            cfg = cfg or {}
            local nm  = cfg.Name or "Keybind"
            local def = cfg.Default or Enum.KeyCode.Unknown
            local cb  = { fn = cfg.Callback or function() end }
            local cur = def ; local listening = false
            local card = mkCard(52) ; hdr(card, nm, "", 120)

            local keyBtn = Instance.new("TextButton")
            keyBtn.Size = UDim2.new(0, 106, 0, 36) ; keyBtn.Position = UDim2.new(1, -114, 0.5, -18)
            keyBtn.BackgroundColor3 = C.DARK ; keyBtn.Text = def.Name
            keyBtn.TextColor3 = C.TXT_LT ; keyBtn.Font = Enum.Font.GothamBold ; keyBtn.TextSize = 12
            keyBtn.TextTruncate = Enum.TextTruncate.AtEnd
            keyBtn.BorderSizePixel = 0 ; keyBtn.AutoButtonColor = false ; keyBtn.Parent = card
            addCorner(keyBtn, 7) ; addPadding(keyBtn, 0, 6, 0, 6)
            keyBtn.MouseEnter:Connect(function() tw(keyBtn, { BackgroundColor3 = C.HOVER }) end)
            keyBtn.MouseLeave:Connect(function() tw(keyBtn, { BackgroundColor3 = C.DARK  }) end)

            local conn = nil
            keyBtn.MouseButton1Click:Connect(function()
                if listening then return end
                listening = true ; keyBtn.Text = "…" ; keyBtn.TextColor3 = C.BG
                conn = UserInputService.InputBegan:Connect(function(input, gp)
                    if gp then return end
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        cur = input.KeyCode ; keyBtn.Text = input.KeyCode.Name
                        keyBtn.TextColor3 = C.TXT_LT ; listening = false
                        cb.fn(input.KeyCode)
                        if conn then conn:Disconnect() ; conn = nil end
                    end
                end)
            end)
            return {
                Instance = card, GetKey = function() return cur end,
                SetCallback = function(_, f) cb.fn = f end,
            }
        end

        function Tab:AddColorPicker(cfg)
            cfg = cfg or {}
            local nm   = cfg.Name or "Color"
            local cdef = cfg.Default or Color3.fromRGB(240, 198, 116)
            local cb   = { fn = cfg.Callback or function() end }
            local HH   = 60 ; local RH = 52 ; local GAP = 6
            local ROWSH = 3 * RH + 2 * GAP
            local OPENH = HH + ROWSH + 20
            local isOpen = false

            local card = makeFrame(tabFrame, {
                Size = UDim2.new(1, 0, 0, HH),
                BackgroundColor3 = C.CARD, BackgroundTransparency = 0,
                ClipsDescendants = true,
            })
            addCorner(card, 8)

            local nL = Instance.new("TextLabel")
            nL.Size = UDim2.new(1, -110, 0, HH) ; nL.Position = UDim2.new(0, 12, 0, 0)
            nL.BackgroundTransparency = 1 ; nL.Text = nm ; nL.TextColor3 = C.TXT_DK
            nL.Font = Enum.Font.GothamBold ; nL.TextSize = 14
            nL.TextXAlignment = Enum.TextXAlignment.Left ; nL.Parent = card

            local swatch = Instance.new("TextButton")
            swatch.Size = UDim2.fromOffset(94, 40) ; swatch.Position = UDim2.new(1, -102, 0.5, -20)
            swatch.BackgroundColor3 = cdef ; swatch.Text = ""
            swatch.BorderSizePixel = 0 ; swatch.AutoButtonColor = false ; swatch.Parent = card
            addCorner(swatch, 7)
            local hexLbl = Instance.new("TextLabel")
            hexLbl.Size = UDim2.fromScale(1, 1) ; hexLbl.BackgroundTransparency = 1
            hexLbl.Text = toHex(cdef) ; hexLbl.TextColor3 = Color3.fromRGB(255, 255, 255)
            hexLbl.Font = Enum.Font.GothamBold ; hexLbl.TextSize = 11 ; hexLbl.Parent = swatch

            local pickContent = makeFrame(card, {
                Size = UDim2.new(1, -24, 0, ROWSH),
                Position = UDim2.new(0, 12, 0, HH + 8),
            })
            makeListLayout(pickContent, Enum.FillDirection.Vertical,
                Enum.HorizontalAlignment.Left, Enum.VerticalAlignment.Top, GAP)

            local rV = math.round(cdef.R * 255)
            local gV = math.round(cdef.G * 255)
            local bV = math.round(cdef.B * 255)

            local function updateColor()
                local col = Color3.fromRGB(rV, gV, bV)
                swatch.BackgroundColor3 = col ; hexLbl.Text = toHex(col) ; cb.fn(col)
            end

            local function mkChannelRow(label, def, fillClr, onChange)
                local row = makeFrame(pickContent, { Size = UDim2.new(1, 0, 0, RH) })
                local lbl = Instance.new("TextLabel")
                lbl.Size = UDim2.fromOffset(14, 18) ; lbl.BackgroundTransparency = 1
                lbl.Text = label ; lbl.TextColor3 = C.TXT_DK
                lbl.Font = Enum.Font.GothamBold ; lbl.TextSize = 13 ; lbl.Parent = row
                local numLbl = Instance.new("TextLabel")
                numLbl.Size = UDim2.fromOffset(30, 18) ; numLbl.Position = UDim2.new(1, -30, 0, 0)
                numLbl.BackgroundTransparency = 1 ; numLbl.Text = tostring(def)
                numLbl.TextColor3 = C.TXT_DK ; numLbl.Font = Enum.Font.Gotham ; numLbl.TextSize = 12
                numLbl.TextXAlignment = Enum.TextXAlignment.Right ; numLbl.Parent = row
                local sw = makeFrame(row, {
                    Size = UDim2.new(1, 0, 0, RH - 18), Position = UDim2.new(0, 0, 0, 18),
                })
                buildSlider(sw, 0, 255, def, fillClr, function(v)
                    numLbl.Text = tostring(v) ; onChange(v)
                end)
            end

            mkChannelRow("R", rV, Color3.fromRGB(200, 60, 60),  function(v) rV = v ; updateColor() end)
            mkChannelRow("G", gV, Color3.fromRGB(60, 180, 60),  function(v) gV = v ; updateColor() end)
            mkChannelRow("B", bV, Color3.fromRGB(60, 100, 220), function(v) bV = v ; updateColor() end)

            swatch.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                tw(card, { Size = UDim2.new(1, 0, 0, isOpen and OPENH or HH) })
            end)
            return {
                Instance = card,
                GetColor = function() return Color3.fromRGB(rV, gV, bV) end,
                SetCallback = function(_, f) cb.fn = f end,
            }
        end

        function Tab:AddLabel(cfg)
            cfg = cfg or {}
            local lbl = Instance.new("TextLabel")
            lbl.Size = UDim2.new(1, 0, 0, 20) ; lbl.BackgroundTransparency = 1
            lbl.Text = cfg.Text or "Label" ; lbl.TextColor3 = cfg.Color or C.TXT_DK
            lbl.Font = Enum.Font.Gotham ; lbl.TextSize = 14
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            lbl.TextWrapped = true ; lbl.AutomaticSize = Enum.AutomaticSize.Y
            lbl.Parent = tabFrame
            return {
                Instance = lbl,
                SetText  = function(_, t) lbl.Text       = t end,
                SetColor = function(_, c) lbl.TextColor3 = c end,
            }
        end

        function Tab:AddSeparator(cfg)
            cfg = cfg or {} ; local text = cfg.Text or ""
            if text == "" then
                return makeFrame(tabFrame, {
                    Size = UDim2.new(1, 0, 0, 1),
                    BackgroundColor3 = C.DARK, BackgroundTransparency = 0.65,
                })
            else
                local con = makeFrame(tabFrame, { Size = UDim2.new(1, 0, 0, 28) })
                local lbl = Instance.new("TextLabel")
                lbl.Size = UDim2.new(1, 0, 0, 16) ; lbl.Position = UDim2.new(0, 0, 1, -16)
                lbl.BackgroundTransparency = 1 ; lbl.Text = text:upper()
                lbl.TextColor3 = C.TXT_MUT ; lbl.Font = Enum.Font.GothamBold
                lbl.TextSize = 11 ; lbl.TextXAlignment = Enum.TextXAlignment.Left ; lbl.Parent = con
                makeFrame(con, {
                    Size = UDim2.new(1, 0, 0, 1), Position = UDim2.new(0, 0, 1, -1),
                    BackgroundColor3 = C.DARK, BackgroundTransparency = 0.65,
                })
                return con
            end
        end

        return Tab
    end

    function Window:Notify(cfg) CandyUI:Notify(cfg) end

    return Window
end

return CandyUI
