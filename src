    local notif = makeFrame(_notifGui, {
        Size             = UDim2.fromOffset(290, NOTIF_H),
        Position         = UDim2.new(1, 90, 0, yPos),
        BackgroundColor3 = C.NOTIF_BG,
        BackgroundTransparency = 0,
        ZIndex           = 50,
        ClipsDescendants = true,
    })
    addCorner(notif, 10)

    makeFrame(notif, {
        Size             = UDim2.new(0, 4, 1, 0),
        BackgroundColor3 = td.color, BackgroundTransparency = 0, ZIndex = 51,
    })

    local iconLbl = Instance.new("TextLabel")
    iconLbl.Size     = UDim2.fromOffset(30, 30)
    iconLbl.Position = UDim2.new(0, 12, 0.5, -15)
    iconLbl.BackgroundTransparency = 1
    iconLbl.Text     = td.icon
    iconLbl.TextColor3 = td.color
    iconLbl.Font     = Enum.Font.GothamBold
    iconLbl.TextSize = 18
    iconLbl.ZIndex   = 51
    iconLbl.Parent   = notif

    local titleLbl = Instance.new("TextLabel")
    titleLbl.Size     = UDim2.new(1, -78, 0, 20)
    titleLbl.Position = hasDesc and UDim2.new(0, 48, 0, 12) or UDim2.new(0, 48, 0.5, -10)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text     = title
    titleLbl.TextColor3 = C.TXT_LT
    titleLbl.Font     = Enum.Font.GothamBold
    titleLbl.TextSize = 13
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.TextTruncate   = Enum.TextTruncate.AtEnd
    titleLbl.ZIndex  = 51
    titleLbl.Parent  = notif

    if hasDesc then
        local descLbl = Instance.new("TextLabel")
        descLbl.Size     = UDim2.new(1, -78, 0, 28)
        descLbl.Position = UDim2.new(0, 48, 0, 36)
        descLbl.BackgroundTransparency = 1
        descLbl.Text     = desc
        descLbl.TextColor3 = C.NOTIF_SUB
        descLbl.Font     = Enum.Font.Gotham
        descLbl.TextSize = 11
        descLbl.TextXAlignment = Enum.TextXAlignment.Left
        descLbl.TextWrapped    = true
        descLbl.ZIndex  = 51
        descLbl.Parent  = notif
    end

    local closeBtn = Instance.new("TextButton")
    closeBtn.Size     = UDim2.fromOffset(26, 26)
    closeBtn.Position = UDim2.new(1, -28, 0, 4)
    closeBtn.BackgroundTransparency = 1
    closeBtn.Text     = "✕"
    closeBtn.TextColor3 = Color3.fromRGB(100, 100, 100)
    closeBtn.Font     = Enum.Font.GothamBold
    closeBtn.TextSize = 11
    closeBtn.BorderSizePixel  = 0
    closeBtn.AutoButtonColor  = false
    closeBtn.ZIndex  = 52
    closeBtn.Parent  = notif
    closeBtn.MouseEnter:Connect(function() closeBtn.TextColor3 = C.TXT_LT end)
    closeBtn.MouseLeave:Connect(function() closeBtn.TextColor3 = Color3.fromRGB(100, 100, 100) end)

    local pbBg = makeFrame(notif, {
        Size = UDim2.new(1, 0, 0, 3), Position = UDim2.new(0, 0, 1, -3),
        BackgroundColor3 = Color3.fromRGB(40, 40, 40), BackgroundTransparency = 0, ZIndex = 51,
    })
    local pbFill = makeFrame(pbBg, {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = td.color, BackgroundTransparency = 0, ZIndex = 52,
    })

    local item = { frame = notif, height = NOTIF_H }
    table.insert(_notifList, item)

    tw(notif, { Position = UDim2.new(1, -300, 0, yPos) })

    TweenService:Create(pbFill,
        TweenInfo.new(duration, Enum.EasingStyle.Linear),
        { Size = UDim2.new(0, 0, 1, 0) }):Play()

    local dismissed = false
    local function dismiss()
        if dismissed then return end
        dismissed = true
        for i, it in ipairs(_notifList) do
            if it == item then table.remove(_notifList, i) break end
        end
        tw(notif, { Position = UDim2.new(1, 90, 0, notif.Position.Y.Offset) })
        task.delay(0.15, function()
            notif:Destroy()
            reposNotifs()
        end)
    end

    closeBtn.MouseButton1Click:Connect(dismiss)
    task.delay(duration, dismiss)
end

