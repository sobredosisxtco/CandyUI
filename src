        info    = { color = C.BG,                            icon = "ℹ" },
        success = { color = Color3.fromRGB(55,  185,  80),   icon = "✓" },
        warning = { color = Color3.fromRGB(240, 160,  30),   icon = "⚠" },
        error   = { color = Color3.fromRGB(205,  50,  50),   icon = "✕" },
