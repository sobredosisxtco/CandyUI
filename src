local _notifList = {}

local function ensureNotifGui()
    if _notifGui and _notifGui.Parent then return end
    _notifGui = Instance.new("ScreenGui")
    _notifGui.Name          = "CandyUI_Notifs"
    _notifGui.ResetOnSpawn  = false
    _notifGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    _notifGui.IgnoreGuiInset = true
    _notifGui.DisplayOrder  = 999
    _notifList = {}
    local ok = pcall(function()
        _notifGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")
    end)
    if not ok then pcall(function() _notifGui.Parent = game:GetService("CoreGui") end) end
end

local function reposNotifs()
    local y = 10
    for _, item in ipairs(_notifList) do
        if item.frame and item.frame.Parent then
            tw(item.frame, { Position = UDim2.new(1, -300, 0, y) })
            y = y + item.height + 8
        end
    end
end

